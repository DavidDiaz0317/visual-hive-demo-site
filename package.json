{
  "name": "visual-hive-demo-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "mock-api": "node scripts/mock-api.mjs",
    "storybook": "storybook dev --host 127.0.0.1 --port 6006 --no-open",
    "build-storybook": "storybook build --quiet",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "vh:build-source": "npm --prefix ../vis-hive run build",
    "vh:doctor": "node ../vis-hive/packages/cli/dist/index.js doctor --config visual-hive.config.yaml",
    "vh:analyze": "node ../vis-hive/packages/cli/dist/index.js analyze --repo .",
    "vh:recommend": "node ../vis-hive/packages/cli/dist/index.js recommend --repo . --profile complex-app",
    "vh:plan": "node ../vis-hive/packages/cli/dist/index.js plan --config visual-hive.config.yaml --mode pr --changed-files changed-files.txt",
    "vh:plan:docs": "node ../vis-hive/packages/cli/dist/index.js plan --config visual-hive.config.yaml --mode pr --changed-files changed-files.docs.txt --output .visual-hive/plan-docs.json",
    "vh:plan:auth": "node ../vis-hive/packages/cli/dist/index.js plan --config visual-hive.config.yaml --mode pr --changed-files changed-files.auth.txt --output .visual-hive/plan-auth.json",
    "vh:plan:component": "node ../vis-hive/packages/cli/dist/index.js plan --config visual-hive.config.yaml --mode pr --changed-files changed-files.component.txt --output .visual-hive/plan-component.json",
    "vh:plan:canary": "node ../vis-hive/packages/cli/dist/index.js plan --config visual-hive.config.yaml --mode canary --changed-files changed-files.txt --output .visual-hive/plan-canary.json",
    "vh:plan:full": "node ../vis-hive/packages/cli/dist/index.js plan --config visual-hive.config.yaml --mode full --allow-unsafe-targets --output .visual-hive/plan-full.json",
    "vh:plans": "node ../vis-hive/packages/cli/dist/index.js plans --config visual-hive.config.yaml",
    "vh:run": "node ../vis-hive/packages/cli/dist/index.js run --config visual-hive.config.yaml --skip-install --skip-build",
    "vh:run:fullstack": "node ../vis-hive/packages/cli/dist/index.js plan --config visual-hive.config.yaml --mode manual --include-target fullStackPreview --output .visual-hive/plan-fullstack.json && node ../vis-hive/packages/cli/dist/index.js run --config visual-hive.config.yaml --plan .visual-hive/plan-fullstack.json --skip-install --skip-build",
    "vh:run:storybook": "node ../vis-hive/packages/cli/dist/index.js plan --config visual-hive.config.yaml --mode manual --include-target componentLibrary --output .visual-hive/plan-storybook.json && node ../vis-hive/packages/cli/dist/index.js run --config visual-hive.config.yaml --plan .visual-hive/plan-storybook.json --skip-install --skip-build",
    "vh:baselines": "node ../vis-hive/packages/cli/dist/index.js baselines list --config visual-hive.config.yaml --write",
    "vh:mutate": "node ../vis-hive/packages/cli/dist/index.js mutate --config visual-hive.config.yaml --skip-install --skip-build",
    "vh:triage": "node ../vis-hive/packages/cli/dist/index.js triage --config visual-hive.config.yaml",
    "vh:report": "node ../vis-hive/packages/cli/dist/index.js report --config visual-hive.config.yaml",
    "vh:coverage": "node ../vis-hive/packages/cli/dist/index.js coverage --config visual-hive.config.yaml --changed-files changed-files.txt",
    "vh:improve-coverage": "node ../vis-hive/packages/cli/dist/index.js improve-coverage --config visual-hive.config.yaml",
    "vh:contracts": "node ../vis-hive/packages/cli/dist/index.js contracts --config visual-hive.config.yaml --changed-files changed-files.txt",
    "vh:flows": "node ../vis-hive/packages/cli/dist/index.js flows --config visual-hive.config.yaml --changed-files changed-files.txt",
    "vh:targets": "node ../vis-hive/packages/cli/dist/index.js targets --config visual-hive.config.yaml --changed-files changed-files.txt",
    "vh:schedules": "node ../vis-hive/packages/cli/dist/index.js schedules --config visual-hive.config.yaml --changed-files changed-files.txt",
    "vh:workflows": "node ../vis-hive/packages/cli/dist/index.js workflows --config visual-hive.config.yaml",
    "vh:providers": "node ../vis-hive/packages/cli/dist/index.js providers list --config visual-hive.config.yaml --mock-results",
    "vh:provider-plan": "node ../vis-hive/packages/cli/dist/index.js providers plan --config visual-hive.config.yaml --provider argos",
    "vh:provider-handoff": "node ../vis-hive/packages/cli/dist/index.js providers handoff --config visual-hive.config.yaml --provider argos",
    "vh:provider-upload": "node ../vis-hive/packages/cli/dist/index.js providers upload --config visual-hive.config.yaml --provider argos --dry-run",
    "vh:llm": "node ../vis-hive/packages/cli/dist/index.js llm --config visual-hive.config.yaml",
    "vh:llm-decision": "node ../vis-hive/packages/cli/dist/index.js llm decision --config visual-hive.config.yaml --decision keep_disabled --reason \"Prompt-only local demo\"",
    "vh:risk": "node ../vis-hive/packages/cli/dist/index.js risk --config visual-hive.config.yaml",
    "vh:security": "node ../vis-hive/packages/cli/dist/index.js security --config visual-hive.config.yaml",
    "vh:costs": "node ../vis-hive/packages/cli/dist/index.js costs --config visual-hive.config.yaml",
    "vh:readiness": "node ../vis-hive/packages/cli/dist/index.js readiness --config visual-hive.config.yaml",
    "vh:setup-status": "node ../vis-hive/packages/cli/dist/index.js setup-status --config visual-hive.config.yaml",
    "vh:runbook": "node ../vis-hive/packages/cli/dist/index.js runbook --config visual-hive.config.yaml --read-only",
    "vh:snapshot": "node ../vis-hive/packages/cli/dist/index.js snapshot --config visual-hive.config.yaml --read-only",
    "vh:history": "node ../vis-hive/packages/cli/dist/index.js history --config visual-hive.config.yaml --record",
    "vh:artifacts": "node ../vis-hive/packages/cli/dist/index.js artifacts --config visual-hive.config.yaml",
    "vh:evidence": "node ../vis-hive/packages/cli/dist/index.js evidence --config visual-hive.config.yaml",
    "vh:layers": "node ../vis-hive/packages/cli/dist/index.js layers --config visual-hive.config.yaml",
    "vh:verdict": "node ../vis-hive/packages/cli/dist/index.js verdict --config visual-hive.config.yaml",
    "vh:handoff": "node ../vis-hive/packages/cli/dist/index.js handoff --config visual-hive.config.yaml --dry-run --agent quality",
    "vh:handoff-validate": "node ../vis-hive/packages/cli/dist/index.js handoff-validate --config visual-hive.config.yaml",
    "vh:hive-export": "node ../vis-hive/packages/cli/dist/index.js hive export --config visual-hive.config.yaml --dry-run --mode measured",
    "vh:hive-modes": "node ../vis-hive/packages/cli/dist/index.js hive compare-modes --config visual-hive.config.yaml",
    "vh:hive-guarded-preview": "node ../vis-hive/packages/cli/dist/index.js hive guarded-repair-preview --config visual-hive.config.yaml",
    "vh:hive-repair-envelope": "node ../vis-hive/packages/cli/dist/index.js hive repair-request-envelope --config visual-hive.config.yaml",
    "vh:hive-repair-consumer": "node ../vis-hive/packages/cli/dist/index.js hive trusted-repair-consumer-summary --config visual-hive.config.yaml",
    "vh:hive-repair-workflow": "node ../vis-hive/packages/cli/dist/index.js hive trusted-repair-workflow-dry-run --config visual-hive.config.yaml",
    "vh:test-creation": "node ../vis-hive/packages/cli/dist/index.js test-creation-plan --config visual-hive.config.yaml",
    "vh:agent-packet": "node ../vis-hive/packages/cli/dist/index.js agent-packet --config visual-hive.config.yaml --profile repair_agent",
    "vh:agent-packet:handoff": "node ../vis-hive/packages/cli/dist/index.js agent-packet --config visual-hive.config.yaml --profile handoff_agent --output .visual-hive/agent-packet-handoff.json",
    "vh:agent-packet:provider": "node ../vis-hive/packages/cli/dist/index.js agent-packet --config visual-hive.config.yaml --profile provider_specialist --output .visual-hive/agent-packet-provider.json",
    "vh:tools": "node ../vis-hive/packages/cli/dist/index.js tools --config visual-hive.config.yaml",
    "vh:context": "node ../vis-hive/packages/cli/dist/index.js context --config visual-hive.config.yaml",
    "vh:mcp": "node ../vis-hive/packages/cli/dist/index.js mcp --config visual-hive.config.yaml --describe",
    "vh:connections": "node ../vis-hive/packages/cli/dist/index.js connections list --config visual-hive.config.yaml --write",
    "vh:pipeline": "node ../vis-hive/packages/cli/dist/index.js pipeline --config visual-hive.config.yaml --mode pr --changed-files changed-files.txt --skip-install --skip-build --continue-on-error",
    "vh:ui": "node ../vis-hive/packages/cli/dist/index.js ui --config visual-hive.config.yaml --open",
    "vh:suite": "node scripts/run-vh-suite.mjs",
    "vh:all": "node scripts/run-vh-suite.mjs all"
  },
  "dependencies": {
    "@playwright/test": "^1.49.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@storybook/react-vite": "^8.6.14",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "storybook": "^8.6.14"
  }
}
